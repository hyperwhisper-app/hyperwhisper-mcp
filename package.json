{
  "name": "@hyperwhisper/mcp",
  "version": "0.1.1",
  "description": "Model Context Protocol server that wraps the HyperWhisper local HTTP API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hyperwhisper-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hyperwhisper",
    "transcription",
    "speech-to-text",
    "voice"
  ],
  "author": "HyperWhisper",
  "license": "MIT",
  "homepage": "https://hyperwhisper.com/docs/api-reference/local-api/mcp-setup",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
